{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python",
      "excludeFiles": "{results/**,evaluation_results/**,notebooks/**,docs/**,tests/**,examples/**,**/__pycache__/**,*.md}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
